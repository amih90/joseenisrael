---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import { site } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { assetPath, buildLegacyUrlMap, categoryUrl, contentHtml, entrySlug, formatDate, sortedByDate, tagUrl } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: entrySlug(post) }, props: { post } }));
}

const { post } = Astro.props;
const allPosts = sortedByDate(await getCollection('posts'));
const pages = await getCollection('pages');
const legacyUrlMap = buildLegacyUrlMap([...allPosts, ...pages]);
const postHtml = contentHtml(post, legacyUrlMap);
const relatedPosts = allPosts.filter((item) => item.id !== post.id).slice(0, 3);
const categories = post.data.categories?.filter((category) => category !== 'Sin categorizar') || [];
const tags = post.data.tags || [];
---

<BaseLayout title={post.data.title} description={post.data.description || site.description} image={post.data.heroImage || site.heroImage}>
  <main>
    <article>
      <header class="article-hero">
        <div>
          <p class="eyebrow">{formatDate(post.data.pubDate)}</p>
          <h1>{post.data.title}</h1>
          {post.data.description && <p>{post.data.description}</p>}
        </div>
        {post.data.heroImage && <img src={assetPath(post.data.heroImage)} alt="" />}
      </header>
      <div class="article-shell">
        <aside class="article-meta">
          {post.data.author && <p><strong>Autor</strong><span>{post.data.author}</span></p>}
          {categories.length > 0 && (
            <p>
              <strong>Categorias</strong>
              <span class="taxonomy-links">{categories.map((category) => <a href={categoryUrl(category)}>{category}</a>)}</span>
            </p>
          )}
          {tags.length > 0 && (
            <p>
              <strong>Temas</strong>
              <span class="taxonomy-links">{tags.map((tag) => <a href={tagUrl(tag)}>{tag}</a>)}</span>
            </p>
          )}
        </aside>
        <div class="prose article-body">
          <Fragment set:html={postHtml} />
        </div>
      </div>
    </article>
    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Tambien puede interesarte</p>
        <h2>Mas relatos</h2>
      </div>
      <div class="post-grid">
        {relatedPosts.map((item) => <PostCard post={item} />)}
      </div>
    </section>
  </main>
</BaseLayout>