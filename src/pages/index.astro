---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import { galleryImages } from '../data/gallery';
import { site } from '../data/site';
import { teamMembers } from '../data/team';
import BaseLayout from '../layouts/BaseLayout.astro';
import { assetPath, displayName, sortedByDate, withBase } from '../lib/content';

const posts = sortedByDate(await getCollection('posts'));
const latestPosts = posts.slice(0, 3);
const homepageSlides = [
  {
    src: site.heroImage,
    alt: 'Jose mirando hacia Jerusalem y el Domo de la Roca',
  },
  {
    src: '/wp-content/uploads/2021/08/20191115163048_IMG_4914-scaled.jpg',
    alt: 'Vista panoramica de Jerusalem',
  },
  {
    src: '/wp-content/uploads/2021/09/20210329_064129-scaled.jpg',
    alt: 'Paisaje historico de Israel al amanecer',
  },
  {
    src: '/wp-content/uploads/2021/09/20210925_152755-scaled.jpg',
    alt: 'Grupo recorriendo lugares historicos de Israel',
  },
  {
    src: '/wp-content/uploads/2021/10/20210403_103959-1-scaled-e1633757302798.jpg',
    alt: 'Paisaje abierto de Tierra Santa',
  },
  {
    src: '/wp-content/uploads/2021/10/20211015_124810-scaled.jpg',
    alt: 'Recorrido por Israel con guia local',
  },
];
---

<BaseLayout title={site.name} description={site.description} image={homepageSlides[0].src}>
  <main>
    <section class="hero hero--slider" aria-label="Imagenes destacadas de Jos en Israel">
      <div class="hero-slider" aria-hidden="true">
        {homepageSlides.map((slide, index) => (
          <img
            class="hero-slide"
            src={assetPath(slide.src)}
            alt=""
            loading={index === 0 ? 'eager' : 'lazy'}
            style={`--slide-delay: ${index * 6}s`}
          />
        ))}
      </div>
      <div class="hero__overlay"></div>
      <div class="hero__content">
        <p class="eyebrow">Guias locales en Tierra Santa</p>
        <h1>Viajes por Israel con mirada cercana</h1>
        <p>{site.description}</p>
        <div class="hero__actions">
          <a class="button button--primary" href={site.whatsapp}>Planear por WhatsApp</a>
          <a class="button button--light" href={withBase('/viajes/')}>Ver viajes</a>
        </div>
      </div>
      <div class="hero-slider__dots" aria-hidden="true">
        {homepageSlides.map((_slide, index) => <span class="hero-slider__dot" style={`--slide-delay: ${index * 6}s`}></span>)}
      </div>
    </section>

    <section class="section section--intro">
      <div class="section-heading">
        <p class="eyebrow">Tierra Santa en espanol</p>
        <h2>Historias, rutas y lugares santos para preparar tu viaje</h2>
      </div>
    </section>

    <section class="section split-section">
      <div class="section-heading">
        <p class="eyebrow">Ultimos relatos</p>
        <h2>Recorridos para entrar en la historia</h2>
      </div>
      <div class="post-grid post-grid--home">
        {latestPosts.map((post, index) => <PostCard post={post} featured={index === 0} />)}
      </div>
    </section>

    <section class="section gallery-strip">
      <div class="section-heading">
        <p class="eyebrow">Galeria</p>
        <h2>Momentos de los recorridos</h2>
      </div>
      <div class="gallery-preview">
        {galleryImages.slice(0, 6).map((image) => (
          <a href={assetPath(image.src)}>
            <img src={assetPath(image.thumbnail)} alt={image.title || 'Galeria'} loading="lazy" />
          </a>
        ))}
      </div>
      <a class="button button--secondary" href={withBase('/galeria/')}>Abrir galeria</a>
    </section>

    <section class="section team-band">
      <div class="section-heading">
        <p class="eyebrow">Equipo</p>
        <h2>Creadores del proyecto</h2>
      </div>
      <div class="team-row">
        {teamMembers.map((member) => (
          <article class="person-chip">
            <span>{displayName(member.name).charAt(0)}</span>
            <div>
              <h3>{displayName(member.name)}</h3>
              <p>{member.role}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section contact-band">
      <div>
        <p class="eyebrow">Contacto</p>
        <h2>Hablemos de tu viaje</h2>
        <p>Escribenos por WhatsApp o email para preparar una ruta personal, familiar o grupal.</p>
      </div>
      <div class="hero__actions">
        <a class="button button--primary" href={site.whatsapp}>WhatsApp</a>
        <a class="button button--secondary" href={`mailto:${site.email}`}>Email</a>
      </div>
    </section>
  </main>
</BaseLayout>